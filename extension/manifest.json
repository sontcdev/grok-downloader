{
  "manifest_version": 3,
  "name": "Grok Video Creator",
  "version": "1.0.0",
  "description": "Tự động tạo nhiều video từ một ảnh trên Grok.com với các prompt khác nhau",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://grok.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/imagine*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
