{
  "manifest_version": 3,
  "name": "Grok Video Generator",
  "version": "2.0.0",
  "description": "Auto create multiple videos from one image on Grok",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://grok.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://grok.com/imagine*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
